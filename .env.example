# Copy to `.env` and fill in. `.env` is gitignored — never commit your key.
#
#   cp .env.example .env

# Server password (shared by ircserv and the companion's IRC_PASS).
IRC_SERVER_PASSWORD=changeme

# Host port the server is published on (container port is always 6667).
IRC_PORT=6667

# Companion settings.
IRC_NICK=assistant
IRC_CHANNELS=#general

# Claude API — REQUIRED for the ai-assistant service.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-opus-4-8

# ── Optional real-time/web tier (docker compose --profile platform up) ──
REALTIME_PORT=4000
RT_BRIDGE_NICK=rtbridge
RT_DEFAULT_CHANNEL=#general
RT_INBOUND_TOPICS=pg/**,mongo/**,irc-in/**
RUST_LOG=info
